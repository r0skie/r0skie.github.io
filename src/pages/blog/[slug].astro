---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} — r0skie`} description={post.data.description}>
  <style>
    .back {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: #888;
      text-decoration: none;
      font-size: 0.875rem;
      margin-bottom: 2.5rem;
      transition: color 0.2s;
    }

    .back:hover { color: #e8e8e8; }

    .post-header { margin-bottom: 2.5rem; }

    .post-meta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      color: #888;
      margin-bottom: 0.75rem;
    }

    h1 {
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 600;
      letter-spacing: -0.03em;
      line-height: 1.25;
    }

    .content {
      border-top: 1px solid #2a2a2a;
      padding-top: 2rem;
    }

    .content :global(h2) {
      font-size: 1.3rem;
      font-weight: 600;
      margin: 2.5rem 0 1rem;
      letter-spacing: -0.02em;
    }

    .content :global(h3) {
      font-size: 1.1rem;
      font-weight: 600;
      margin: 2rem 0 0.75rem;
    }

    .content :global(p) {
      color: #c8c8c8;
      margin-bottom: 1.25rem;
      line-height: 1.8;
    }

    .content :global(a) { color: #7c6af7; }

    .content :global(code) {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85em;
      background: #1e1e1e;
      padding: 0.15rem 0.4rem;
      border-radius: 4px;
      color: #c8c8c8;
    }

    .content :global(pre) {
      background: #161616;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      padding: 1.25rem;
      overflow-x: auto;
      margin: 1.5rem 0;
    }

    .content :global(pre code) {
      background: none;
      padding: 0;
      font-size: 0.875rem;
    }

    .content :global(ul), .content :global(ol) {
      padding-left: 1.5rem;
      margin-bottom: 1.25rem;
      color: #c8c8c8;
    }

    .content :global(li) { margin-bottom: 0.4rem; line-height: 1.7; }

    .content :global(blockquote) {
      border-left: 3px solid #7c6af7;
      padding: 0.5rem 0 0.5rem 1.25rem;
      margin: 1.5rem 0;
      color: #888;
      font-style: italic;
    }

    .content :global(img) {
      width: 100%;
      border-radius: 8px;
      margin: 1.5rem 0;
    }
  </style>

  <a href="/blog" class="back">← kembali ke blog</a>

  <div class="post-header">
    <p class="post-meta">
      {post.data.date.toLocaleDateString('id-ID', { year:'numeric', month:'long', day:'numeric' })}
    </p>
    <h1>{post.data.title}</h1>
  </div>

  <div class="content">
    <Content />
  </div>
</Layout>
