---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="r0skie — Portfolio & Blog">
  <style>
    .hero {
      padding: 4rem 0 3rem;
      border-bottom: 1px solid #2a2a2a;
      margin-bottom: 3rem;
    }

    .tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      color: #7c6af7;
      background: #7c6af720;
      padding: 0.25rem 0.6rem;
      border-radius: 4px;
      display: inline-block;
      margin-bottom: 1.25rem;
    }

    h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.03em;
      margin-bottom: 1rem;
    }

    .hero p {
      color: #888;
      font-size: 1.05rem;
      max-width: 480px;
      margin-bottom: 2rem;
    }

    .links {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn {
      padding: 0.6rem 1.25rem;
      border-radius: 6px;
      font-size: 0.9rem;
      text-decoration: none;
      font-weight: 500;
      transition: all 0.2s;
    }

    .btn-primary {
      background: #7c6af7;
      color: #fff;
    }

    .btn-primary:hover { background: #6a59e0; }

    .btn-ghost {
      border: 1px solid #2a2a2a;
      color: #888;
    }

    .btn-ghost:hover { border-color: #7c6af7; color: #e8e8e8; }

    .section-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #888;
      margin-bottom: 1.5rem;
    }

    .projects {
      margin-bottom: 3rem;
    }

    .project-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1rem;
    }

    .project-card {
      border: 1px solid #2a2a2a;
      border-radius: 10px;
      padding: 1.5rem;
      transition: border-color 0.2s, background 0.2s;
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .project-card:hover {
      border-color: #7c6af7;
      background: #7c6af708;
    }

    .project-card h3 {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 0.4rem;
    }

    .project-card p {
      color: #888;
      font-size: 0.875rem;
      line-height: 1.6;
      margin-bottom: 0.75rem;
    }

    .tech-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .tech {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: #7c6af7;
      background: #7c6af715;
      padding: 0.15rem 0.5rem;
      border-radius: 3px;
    }

    .blog-section { margin-bottom: 3rem; }

    .blog-list { display: flex; flex-direction: column; gap: 0; }

    .blog-item {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 1rem 0;
      border-bottom: 1px solid #1e1e1e;
      text-decoration: none;
      color: inherit;
      gap: 1rem;
      transition: color 0.2s;
    }

    .blog-item:hover .blog-title { color: #7c6af7; }

    .blog-title { font-size: 0.95rem; font-weight: 500; }

    .blog-date {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      color: #888;
      white-space: nowrap;
    }

    .view-all {
      display: inline-block;
      margin-top: 1.25rem;
      font-size: 0.85rem;
      color: #7c6af7;
      text-decoration: none;
    }

    .view-all:hover { text-decoration: underline; }
  </style>

  <!-- Hero -->
  <section class="hero">
    <span class="tag">available for work</span>
    <h1>Hi, aku r0skie 👋</h1>
    <p>Developer & kreator konten. Suka eksplorasi teknologi baru dan berbagi hal-hal yang aku pelajari di blog ini.</p>
    <div class="links">
      <a href="https://github.com/r0skie" class="btn btn-primary" target="_blank">GitHub</a>
      <a href="/blog" class="btn btn-ghost">Baca Blog →</a>
    </div>
  </section>

  <!-- Projects -->
  <section class="projects">
    <p class="section-label">// projects</p>
    <div class="project-grid">
      <a href="https://github.com/r0skie" class="project-card" target="_blank">
        <h3>Project Pertama</h3>
        <p>Deskripsi singkat project kamu. Ganti ini dengan project nyata yang pernah kamu buat.</p>
        <div class="tech-stack">
          <span class="tech">JavaScript</span>
          <span class="tech">Node.js</span>
        </div>
      </a>
      <a href="https://github.com/r0skie" class="project-card" target="_blank">
        <h3>Project Kedua</h3>
        <p>Deskripsi singkat project kamu. Ganti ini dengan project nyata yang pernah kamu buat.</p>
        <div class="tech-stack">
          <span class="tech">Python</span>
          <span class="tech">API</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Blog terbaru -->
  <section class="blog-section">
    <p class="section-label">// tulisan terbaru</p>
    <div class="blog-list">
      {posts.length === 0 ? (
        <p style="color:#888; font-size:0.9rem;">Belum ada tulisan. Cek folder <code>src/content/blog/</code> untuk mulai nulis!</p>
      ) : (
        posts.map(post => (
          <a href={`/blog/${post.slug}`} class="blog-item">
            <span class="blog-title">{post.data.title}</span>
            <span class="blog-date">{post.data.date.toLocaleDateString('id-ID', { year:'numeric', month:'short', day:'numeric' })}</span>
          </a>
        ))
      )}
    </div>
    <a href="/blog" class="view-all">Semua tulisan →</a>
  </section>
</Layout>
