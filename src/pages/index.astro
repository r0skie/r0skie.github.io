<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dio — Personal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    /* ── Token System ───────────────────────────── */
    :root {
      --bg:        #0f0f0f;
      --surface:   #161616;
      --border:    #242424;
      --muted:     #555;
      --body:      #a8a8a8;
      --heading:   #e8e8e8;
      --accent:    #4a8fff;
      --accent-dim:#1a3a6e;

      --font-mono: 'IBM Plex Mono', monospace;
      --font-sans: 'Inter', sans-serif;
    }

    /* ── Reset ──────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--body);
      font-family: var(--font-sans);
      font-size: 15px;
      line-height: 1.7;
      min-height: 100vh;
    }

    a {
      color: var(--accent);
      text-decoration: none;
      transition: opacity 0.15s;
    }
    a:hover { opacity: 0.75; }

    /* ── Layout ─────────────────────────────────── */
    .container {
      max-width: 640px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ── Nav ────────────────────────────────────── */
    nav {
      border-bottom: 1px solid var(--border);
      padding: 20px 0;
      position: sticky;
      top: 0;
      background: var(--bg);
      z-index: 10;
    }

    nav .container {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--heading);
      letter-spacing: 0.04em;
    }

    .nav-logo span {
      color: var(--accent);
    }

    .nav-links {
      display: flex;
      gap: 24px;
      list-style: none;
    }

    .nav-links a {
      font-size: 13px;
      color: var(--muted);
      letter-spacing: 0.03em;
    }

    .nav-links a:hover {
      color: var(--body);
      opacity: 1;
    }

    /* ── Hero ───────────────────────────────────── */
    .hero {
      padding: 80px 0 60px;
      border-bottom: 1px solid var(--border);
    }

    .hero-label {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--accent);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 20px;
    }

    .hero h1 {
      font-family: var(--font-sans);
      font-size: clamp(32px, 5vw, 48px);
      font-weight: 300;
      color: var(--heading);
      line-height: 1.2;
      margin-bottom: 20px;
      letter-spacing: -0.02em;
    }

    .hero h1 strong {
      font-weight: 500;
    }

    .hero p {
      font-size: 15px;
      color: var(--body);
      max-width: 480px;
      line-height: 1.75;
    }

    /* ── Sections ───────────────────────────────── */
    section {
      padding: 56px 0;
      border-bottom: 1px solid var(--border);
    }

    .section-label {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 28px;
    }

    /* ── About ──────────────────────────────────── */
    .about-text p {
      margin-bottom: 14px;
      color: var(--body);
    }

    .about-text p:last-child { margin-bottom: 0; }

    /* ── Contact ────────────────────────────────── */
    .contact-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .contact-icon {
      width: 36px;
      height: 36px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .contact-icon svg {
      width: 16px;
      height: 16px;
      fill: var(--muted);
    }

    .contact-meta {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .contact-type {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .contact-value {
      font-size: 14px;
      color: var(--heading);
    }

    /* ── Footer ─────────────────────────────────── */
    footer {
      padding: 32px 0;
    }

    footer p {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.04em;
    }

    /* ── Cursor blink ───────────────────────────── */
    .cursor {
      display: inline-block;
      width: 2px;
      height: 1em;
      background: var(--accent);
      vertical-align: text-bottom;
      margin-left: 3px;
      animation: blink 1.1s step-end infinite;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0; }
    }

    /* ── Responsive ─────────────────────────────── */
    @media (max-width: 480px) {
      .hero { padding: 56px 0 44px; }
      section { padding: 44px 0; }
    }

    /* ── Reduced motion ─────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
      .cursor { animation: none; opacity: 1; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <div class="container">
      <span class="nav-logo">Dio<span>.</span></span>
      <ul class="nav-links">
        <li><a href="#about">tentang</a></li>
        <li><a href="/blog">blog</a></li>
        <li><a href="#contact">kontak</a></li>
      </ul>
    </div>
  </nav>

  <!-- HERO -->
  <header class="hero">
    <div class="container">
      <p class="hero-label">// personal space</p>
      <h1>Hei, saya <strong>Dio</strong>.<span class="cursor"></span></h1>
      <p>
        Ini tempat saya nulis, nyimpen catatan, dan sesekali berbagi hal yang menurut saya menarik.
        Bukan blog serius — cuma ruang kecil di internet.
      </p>
    </div>
  </header>

  <!-- ABOUT -->
  <section id="about">
    <div class="container">
      <p class="section-label">// tentang</p>
      <div class="about-text">
        <p>
          Saya Dio. Suka eksplorasi hal baru, terutama yang berbau teknologi dan hal-hal di sekitarnya.
        </p>
        <p>
          Blog ini bukan tempat yang terlalu serius. Saya tulis apa yang menurut saya perlu ditulis —
          kadang teknis, kadang random.
        </p>
        <p>
          Kalau mau ngobrol atau kolaborasi, pintunya selalu terbuka.
        </p>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <div class="container">
      <p class="section-label">// kontak</p>
      <ul class="contact-list">

        <!-- Email -->
        <li class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 4H4C2.9 4 2 4.9 2 6v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </div>
          <div class="contact-meta">
            <span class="contact-type">email</span>
            <a class="contact-value" href="mailto:diotorisasi@gmail.com">diotorisasi@gmail.com</a>
          </div>
        </li>

        <!-- GitHub -->
        <li class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
          </div>
          <div class="contact-meta">
            <span class="contact-type">github</span>
            <a class="contact-value" href="https://github.com/r0skie" target="_blank" rel="noopener">github.com/r0skie</a>
          </div>
        </li>

        <!-- Discord -->
        <li class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.317 4.492c-1.53-.69-3.17-1.2-4.885-1.49a.075.075 0 0 0-.079.036c-.21.369-.444.85-.608 1.23a18.566 18.566 0 0 0-5.487 0 12.36 12.36 0 0 0-.617-1.23A.077.077 0 0 0 8.562 3c-1.714.29-3.354.8-4.885 1.491a.07.07 0 0 0-.032.027C.533 9.093-.32 13.555.099 17.961a.08.08 0 0 0 .031.055 20.03 20.03 0 0 0 5.993 2.98.078.078 0 0 0 .084-.026 13.83 13.83 0 0 0 1.226-1.963.074.074 0 0 0-.041-.104 13.175 13.175 0 0 1-1.872-.878.075.075 0 0 1-.008-.125c.126-.093.252-.19.372-.287a.075.075 0 0 1 .078-.01c3.927 1.764 8.18 1.764 12.061 0a.075.075 0 0 1 .079.009c.12.098.245.195.372.288a.075.075 0 0 1-.006.125c-.598.344-1.22.635-1.873.877a.075.075 0 0 0-.041.105c.36.687.772 1.341 1.225 1.962a.077.077 0 0 0 .084.028 19.963 19.963 0 0 0 6.002-2.981.076.076 0 0 0 .032-.054c.5-5.094-.838-9.52-3.549-13.442a.06.06 0 0 0-.031-.028zM8.02 15.278c-1.182 0-2.157-1.069-2.157-2.38 0-1.312.956-2.38 2.157-2.38 1.21 0 2.176 1.077 2.157 2.38 0 1.312-.956 2.38-2.157 2.38zm7.975 0c-1.183 0-2.157-1.069-2.157-2.38 0-1.312.955-2.38 2.157-2.38 1.21 0 2.176 1.077 2.157 2.38 0 1.312-.946 2.38-2.157 2.38z"/>
            </svg>
          </div>
          <div class="contact-meta">
            <span class="contact-type">discord</span>
            <span class="contact-value">arrafiq</span>
          </div>
        </li>

      </ul>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <p>dibuat sendiri · 2025 · Dio</p>
    </div>
  </footer>

</body>
</html>
